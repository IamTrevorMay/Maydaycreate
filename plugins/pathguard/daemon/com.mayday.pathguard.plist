<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mayday.pathguard</string>

    <key>ProgramArguments</key>
    <array>
        <!-- UPDATE: Set this to your node path -->
        <string>/usr/local/bin/node</string>
        <!-- UPDATE: Set this to the built daemon entry point -->
        <string>/path/to/MaydayCreate/plugins/pathguard/daemon/dist/index.mjs</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/pathguard-daemon.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/pathguard-daemon.err</string>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
