{
  "name": "@mayday/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./theme": { "types": "./dist/theme.d.ts", "import": "./dist/theme.js" }
  },
  "scripts": {
    "build": "tsup src/index.ts src/theme.ts --format esm --dts --external react",
    "dev": "tsup src/index.ts src/theme.ts --format esm --dts --external react --watch"
  },
  "dependencies": {
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
