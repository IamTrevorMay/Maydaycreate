{
  "name": "@mayday/launcher",
  "version": "1.0.0",
  "private": true,
  "description": "Plugin development platform for Adobe Premiere Pro",
  "author": "Mayday",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@mayday/sdk": "*",
    "@mayday/server": "*",
    "@mayday/sync-engine": "*",
    "@mayday/types": "*",
    "@mayday/ui-kit": "*",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0",
    "yt-dlp-wrap": "^2.3.12",
    "@supabase/supabase-js": "^2.99.2",
    "@anthropic-ai/sdk": "^0.78.0",
    "brain.js": "^2.0.0-beta.23",
    "gpu.js": "^2.16.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.mayday.create",
    "productName": "Mayday Create",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "!**/node_modules/.bin/**"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/@esbuild/**",
      "node_modules/esbuild/**",
      "node_modules/@mayday/sdk/**",
      "node_modules/@mayday/types/**",
      "node_modules/better-sqlite3/**",
      "node_modules/brain.js/**",
      "node_modules/gpu.js/**",
      "node_modules/gpu-mock.js/**",
      "node_modules/webgpu/**"
    ],
    "extraResources": [
      {
        "from": "../../plugins",
        "to": "plugins",
        "filter": [
          "**/*",
          "!**/node_modules/**",
          "!**/.mayday-build/**",
          "!**/.bin/**"
        ]
      },
      {
        "from": "../../tools/streamdeck-worker",
        "to": "streamdeck-worker",
        "filter": [
          "**/*",
          "!**/node_modules/**",
          "!**/.bin/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "identity": "Developer ID Application",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Mayday Create",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "IamTrevorMay",
      "repo": "Maydaycreate"
    },
    "npmRebuild": true,
    "electronVersion": "31.7.7"
  }
}
